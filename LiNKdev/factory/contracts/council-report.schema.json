{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linktrend.dev/LiNKdev/council-report.schema.json",
  "title": "DevSwarmCouncilReport",
  "type": "object",
  "required": [
    "gate",
    "program_id",
    "personas",
    "summary_status",
    "blockers"
  ],
  "additionalProperties": true,
  "properties": {
    "gate": {
      "type": "string",
      "enum": ["G1", "G2", "G3", "G4"]
    },
    "program_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "module_id": {
      "type": "string",
      "minLength": 1
    },
    "phase_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "path"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "personas": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["persona_id", "verdict", "summary", "evidence"],
        "additionalProperties": false,
        "properties": {
          "persona_id": {
            "type": "string",
            "enum": [
              "security-advisor",
              "architecture-advisor",
              "dx-advisor",
              "qa-advisor",
              "product-advisor"
            ]
          },
          "verdict": {
            "type": "string",
            "enum": ["PASS", "WARN", "BLOCKER"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["type", "ref", "finding"],
              "additionalProperties": false,
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["file", "command", "report", "narrative"]
                },
                "ref": { "type": "string", "minLength": 1 },
                "finding": { "type": "string", "minLength": 1 }
              }
            }
          },
          "warnings": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "recommendations": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "summary_status": {
      "type": "string",
      "enum": ["PASS", "WARN", "BLOCKER"]
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["persona_id", "message"],
        "additionalProperties": false,
        "properties": {
          "persona_id": {
            "type": "string",
            "enum": [
              "security-advisor",
              "architecture-advisor",
              "dx-advisor",
              "qa-advisor",
              "product-advisor"
            ]
          },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["persona_id", "message"],
        "additionalProperties": false,
        "properties": {
          "persona_id": {
            "type": "string",
            "enum": [
              "security-advisor",
              "architecture-advisor",
              "dx-advisor",
              "qa-advisor",
              "product-advisor"
            ]
          },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    },
    "summary_markdown_path": {
      "type": "string",
      "minLength": 1
    }
  }
}
