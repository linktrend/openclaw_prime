{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linktrend.dev/LiNKdev/intent-verdict.schema.json",
  "title": "DevSwarmIntentVerdict",
  "type": "object",
  "required": [
    "program_id",
    "status",
    "laws_checked",
    "requirements_checked",
    "blockers",
    "timestamp"
  ],
  "additionalProperties": false,
  "properties": {
    "program_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL", "BLOCKED"]
    },
    "laws_checked": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^LAW-[0-9]{2}$"
      },
      "minItems": 8,
      "uniqueItems": true
    },
    "requirements_checked": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "planner_narrative_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "PASS" } }, "required": ["status"] },
      "then": { "properties": { "blockers": { "maxItems": 0 } } }
    },
    {
      "if": {
        "properties": { "status": { "enum": ["FAIL", "BLOCKED"] } },
        "required": ["status"]
      },
      "then": { "properties": { "blockers": { "minItems": 1 } } }
    }
  ]
}
