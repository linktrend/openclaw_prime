{
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": {
        "source": "env",
        "provider": "default",
        "id": "OPENCLAW_GATEWAY_TOKEN"
      }
    },
    "controlUi": {
      "allowedOrigins": ["https://linkbot.linktrend.internal"]
    },
    "linktrendAgentRun": {
      "path": "/v1/linktrend/agent-run"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/data/workspace/shared",
      "userTimezone": "Asia/Taipei",
      "skipBootstrap": true,
      "model": {
        "primary": "openrouter/anthropic/claude-sonnet-4-6"
      },
      "subagents": {
        "model": {
          "primary": "openrouter/anthropic/claude-haiku-4-5"
        },
        "maxConcurrent": 8,
        "archiveAfterMinutes": 60
      }
    },
    "list": [
      {
        "id": "admin-openclaw",
        "name": "Admin OpenClaw",
        "workspace": "/data/workspace/admin-openclaw",
        "agentDir": "/data/.openclaw/agents/admin-openclaw/agent"
      },
      {
        "id": "ceo-client",
        "name": "Client CEO",
        "default": true,
        "workspace": "/data/workspace/ceo-client",
        "agentDir": "/data/.openclaw/agents/ceo-client/agent"
      },
      {
        "id": "linksites-head",
        "name": "LinkSites Head",
        "workspace": "/data/workspace/linksites-head",
        "agentDir": "/data/.openclaw/agents/linksites-head/agent"
      },
      {
        "id": "linkdeveloper-orchestrator",
        "name": "LiNKdeveloper Orchestrator",
        "workspace": "/data/workspace/linkdeveloper-orchestrator",
        "agentDir": "/data/.openclaw/agents/linkdeveloper-orchestrator/agent"
      },
      {
        "id": "linkdeveloper-steward",
        "name": "LiNKdeveloper Steward",
        "workspace": "/data/workspace/linkdeveloper-steward",
        "agentDir": "/data/.openclaw/agents/linkdeveloper-steward/agent"
      }
    ]
  },
  "plugins": {
    "entries": {
      "openrouter": {
        "enabled": true
      }
    }
  }
}
