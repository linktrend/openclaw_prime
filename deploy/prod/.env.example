# Production deploy pointers for OpenClaw gateway (LiNKbot-core).
# Commit secret names only. Render runtime values on the VPS:
#   ./ops/render-runtime-env-from-gsm.sh prod --output /opt/linktrend/runtime/linkbot-core/prod.env.runtime

OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_TZ=Asia/Taipei

OPENCLAW_STATE_DIR=/data/.openclaw
OPENCLAW_CONFIG_DIR=/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace
OPENCLAW_RUNTIME_ENV_FILE=/opt/linktrend/runtime/linkbot-core/prod.env.runtime

OPENCLAW_IMAGE=linkbot-core:local

TRAEFIK_ROUTER_NAME=linkbot
TRAEFIK_HOST=linkbot.linktrend.internal
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_DOCKER_NETWORK=linktrend-network

LINKBOT_STATE_CONFIG_DIR=/opt/linktrend/data/linkbot-core/state/config
LINKBOT_STATE_WORKSPACE_DIR=/opt/linktrend/data/linkbot-core/state/workspace

GCP_PROJECT_ID=linkbot-901208

# GSM-backed secrets (names must exist in GCP project)
OPENCLAW_GATEWAY_TOKEN_SECRET_NAME=LINKTREND_LINKBOT_PROD_GATEWAY_TOKEN
OPENCLAW_LINKTREND_RUN_BEARER_SECRET_NAME=LINKTREND_AIOS_PROD_AIOS_INGRESS_TOKEN
OPENROUTER_API_KEY_SECRET_NAME=LINKTREND_AIOS_PROD_OPENROUTER_API_KEY
OPENAI_API_KEY_SECRET_NAME=LINKTREND_LISA_EXECUTION_OPENAI_API_KEY
